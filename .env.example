# Formula Foundry — Environment Variables
# Copy to .env.local and fill in your keys before running.

ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Blackboard API (default for local dev)
BLACKBOARD_API_URL=http://localhost:8000

# Evolution daemon
EVOLUTION_POLL_SECONDS=60
EVOLUTION_MAX_CONCURRENT=3
