# Formula Foundry — Master Indicator Corpus v1.0
# 
# This file defines the seed indicators for the Formula Foundry Blackboard.
# Each indicator becomes a FormulaDNA object with proof_status=HYPOTHESIS.
# The synthesis agents discover connections between these formulas,
# propose unified formulas, and the auditor agents prove them.
#
# Format: JSON-lines (one JSON object per line)
# Ingestion: scripts/seed_indicators.py reads this file and POSTs to the Blackboard API.
#
# Categories:
#   MA    — Moving Averages & Trend Filters
#   OSC   — Oscillators & Momentum
#   VOL   — Volatility, Bands & Channels
#   VLUM  — Volume Indicators
#   OVR   — Overlays & Specialized Trend
#   OF    — Order Flow & Microstructure  (NEW — our core competency)
#   MS    — Market Structure & Price Action (NEW)
#   STAT  — Statistical & Regression-Based (NEW)
#   SENT  — Sentiment & Positioning Proxies (NEW)
#   ADV   — Advanced / Proprietary
#
# Fields:
#   category:           Category code (above)
#   name:               Human-readable indicator name
#   formula_latex:      LaTeX representation of the formula
#   formula_sympy:      SymPy-parseable expression (where possible)
#   default_params:     Default parameter values
#   behavioral_claim:   What behavioral phenomenon this indicator captures
#   mathematical_wing:  Which Formula Foundry mathematical wing(s) apply
#   tags:               Searchable tags for Librarian pairing
#   source:             Original author / source
#   notes:              Implementation notes, edge cases

# ═══════════════════════════════════════════════════════════════════════
# MOVING AVERAGES & TREND FILTERS (MA)
# ═══════════════════════════════════════════════════════════════════════

{"category": "MA", "name": "Simple Moving Average (SMA)", "formula_latex": "SMA_n = \\frac{1}{n} \\sum_{i=1}^{n} C_i", "formula_sympy": "Sum(C_i, (i, 1, n)) / n", "default_params": {"n": [9, 14, 20, 50, 200]}, "behavioral_claim": "The arithmetic mean of recent closes acts as a dynamic support/resistance level because it represents the average cost basis of participants over the lookback period. Price returning to SMA reflects mean-reversion of aggregate positioning.", "mathematical_wing": ["functional_analysis"], "tags": ["trend", "moving_average", "mean_reversion", "support_resistance"], "source": "Classical", "notes": "Equal weighting assumes all observations equally relevant — violated during regime changes."}

{"category": "MA", "name": "Exponential Moving Average (EMA)", "formula_latex": "EMA_t = \\alpha C_t + (1-\\alpha) EMA_{t-1}, \\quad \\alpha = \\frac{2}{n+1}", "formula_sympy": "alpha * C_t + (1 - alpha) * EMA_prev", "default_params": {"n": [9, 21], "alpha": "2/(n+1)"}, "behavioral_claim": "Exponential decay weighting captures recency bias in participant behavior — recent price action dominates positioning decisions more than distant history. The recursive structure models memory decay in market attention.", "mathematical_wing": ["functional_analysis"], "tags": ["trend", "moving_average", "recency_bias", "memory_decay"], "source": "Classical", "notes": "Infinite impulse response — never fully forgets old data."}

{"category": "MA", "name": "Weighted Moving Average (WMA)", "formula_latex": "WMA_n = \\frac{n C_n + (n-1) C_{n-1} + \\cdots + C_1}{n(n+1)/2}", "formula_sympy": "Sum(i * C_i, (i, 1, n)) / (n * (n + 1) / 2)", "default_params": {"n": 9}, "behavioral_claim": "Linear weight decay provides a middle ground between SMA's equal weighting and EMA's exponential decay, capturing the gradual fading of older price levels from participant memory.", "mathematical_wing": ["functional_analysis"], "tags": ["trend", "moving_average", "linear_decay"], "source": "Classical", "notes": "Finite impulse response — cleanly forgets data older than n bars."}

{"category": "MA", "name": "Volume Weighted Moving Average (VWMA)", "formula_latex": "VWMA_n = \\frac{\\sum_{i=1}^{n} C_i V_i}{\\sum_{i=1}^{n} V_i}", "formula_sympy": "Sum(C_i * V_i, (i, 1, n)) / Sum(V_i, (i, 1, n))", "default_params": {"n": 20}, "behavioral_claim": "Weighting by volume gives higher influence to prices where more capital was committed, revealing the true average cost basis of active participants rather than the time-weighted average.", "mathematical_wing": ["functional_analysis", "measure_theory"], "tags": ["trend", "moving_average", "volume_weighted", "cost_basis"], "source": "Classical", "notes": "Divergence from SMA signals volume-price disagreement."}

{"category": "MA", "name": "Hull Moving Average (HMA)", "formula_latex": "HMA = WMA\\left(2 \\cdot WMA(n/2) - WMA(n), \\sqrt{n}\\right)", "formula_sympy": "WMA(2 * WMA(C, n/2) - WMA(C, n), sqrt(n))", "default_params": {"n": 9}, "behavioral_claim": "Double-differencing of WMAs at different scales eliminates lag while preserving smoothness, capturing trend changes at the speed participants actually react to them rather than with artificial delay.", "mathematical_wing": ["functional_analysis"], "tags": ["trend", "moving_average", "low_lag", "double_differencing"], "source": "Alan Hull", "notes": "Can overshoot on sharp reversals due to the 2x amplification."}

{"category": "MA", "name": "Arnaud Legoux Moving Average (ALMA)", "formula_latex": "ALMA = \\sum_{i=0}^{n-1} w_i C_{n-i}, \\quad w_i = e^{-\\frac{(i - m)^2}{2\\sigma^2}}", "formula_sympy": "Sum(exp(-(i - m)**2 / (2 * sigma**2)) * C_(n-i), (i, 0, n-1))", "default_params": {"n": 9, "offset": 0.85, "sigma": 6}, "behavioral_claim": "Gaussian-weighted averaging with adjustable center of mass captures the non-uniform attention distribution of participants — most attention clusters around a specific recency point, not uniformly across the window.", "mathematical_wing": ["probability_information", "functional_analysis"], "tags": ["trend", "moving_average", "gaussian", "attention_distribution"], "source": "Arnaud Legoux", "notes": "Offset controls the center of the Gaussian bell along the lookback window."}

{"category": "MA", "name": "Kaufman Adaptive Moving Average (KAMA)", "formula_latex": "KAMA_t = KAMA_{t-1} + sc^2 (C_t - KAMA_{t-1}), \\quad sc = ER \\cdot (fast - slow) + slow", "formula_sympy": "KAMA_prev + sc**2 * (C_t - KAMA_prev)", "default_params": {"n": 10, "fast_period": 2, "slow_period": 30}, "behavioral_claim": "Adapting smoothing speed to the efficiency ratio (directional movement vs total movement) captures the regime-dependent response speed of participants — fast during trends, slow during chop.", "mathematical_wing": ["functional_analysis", "ergodic_theory"], "tags": ["trend", "moving_average", "adaptive", "regime_detection", "efficiency_ratio"], "source": "Perry Kaufman", "notes": "Efficiency ratio ER = abs(direction) / volatility over n periods."}

{"category": "MA", "name": "Fractal Adaptive Moving Average (FRAMA)", "formula_latex": "FRAMA_t = \\alpha_t C_t + (1-\\alpha_t) FRAMA_{t-1}, \\quad \\alpha_t = e^{-4.6(D-1)}", "formula_sympy": "alpha_t * C_t + (1 - alpha_t) * FRAMA_prev", "default_params": {"N": 16}, "behavioral_claim": "Adapting smoothing to the fractal dimension of price captures self-similar structure in participant behavior — trending markets have low fractal dimension (smooth), choppy markets have high fractal dimension (rough).", "mathematical_wing": ["topology_geometry", "functional_analysis"], "tags": ["trend", "moving_average", "adaptive", "fractal_dimension", "self_similarity"], "source": "John Ehlers", "notes": "Fractal dimension D estimated from high-low range at two scales."}

{"category": "MA", "name": "McGinley Dynamic", "formula_latex": "MD_t = MD_{t-1} + \\frac{C_t - MD_{t-1}}{k \\cdot (C_t / MD_{t-1})^4 \\cdot n}", "formula_sympy": "MD_prev + (C_t - MD_prev) / (k * (C_t / MD_prev)**4 * n)", "default_params": {"n": 10, "k": 0.6}, "behavioral_claim": "The fourth-power price ratio creates nonlinear speed adjustment — the MA accelerates sharply when price diverges from it, modeling the increasing urgency of participants to chase price as it moves further from consensus.", "mathematical_wing": ["functional_analysis"], "tags": ["trend", "moving_average", "nonlinear", "adaptive", "urgency"], "source": "John McGinley", "notes": "Auto-adjusts speed; rarely requires parameter tuning."}

{"category": "MA", "name": "Double EMA (DEMA)", "formula_latex": "DEMA = 2 \\cdot EMA(C, n) - EMA(EMA(C, n), n)", "formula_sympy": "2 * EMA(C, n) - EMA(EMA(C, n), n)", "default_params": {"n": 9}, "behavioral_claim": "Error-correction via subtracting the smoothed error term reduces lag by removing the systematic bias in EMA's trend-following delay.", "mathematical_wing": ["functional_analysis"], "tags": ["trend", "moving_average", "error_correction", "low_lag"], "source": "Patrick Mulloy", "notes": "Can overshoot; essentially an EMA with lag compensation."}

{"category": "MA", "name": "Triple EMA (TEMA)", "formula_latex": "TEMA = 3 EMA - 3 EMA(EMA) + EMA(EMA(EMA))", "formula_sympy": "3*EMA(C,n) - 3*EMA(EMA(C,n),n) + EMA(EMA(EMA(C,n),n),n)", "default_params": {"n": 9}, "behavioral_claim": "Third-order error correction provides even faster response than DEMA, capturing the fastest possible trend signal within the EMA framework.", "mathematical_wing": ["functional_analysis"], "tags": ["trend", "moving_average", "error_correction", "low_lag"], "source": "Patrick Mulloy", "notes": "Most aggressive lag reduction in the EMA family; can whipsaw."}

{"category": "MA", "name": "Least Squares Moving Average (LSMA)", "formula_latex": "LSMA_t = a + b \\cdot n, \\quad \\text{where } (a,b) = \\text{OLS}(C_{t-n+1}, \\ldots, C_t)", "formula_sympy": "a + b * n", "default_params": {"n": 14}, "behavioral_claim": "The endpoint of the regression line projects the current trend direction, separating systematic trend from noise. Slope captures the rate of consensus shift among participants.", "mathematical_wing": ["functional_analysis"], "tags": ["trend", "moving_average", "regression", "trend_projection"], "source": "Classical", "notes": "Also called Linear Regression Value or Linreg."}

{"category": "MA", "name": "Variable Index Dynamic Average (VIDYA)", "formula_latex": "VIDYA_t = \\alpha |CMO_t| \\cdot C_t + (1 - \\alpha |CMO_t|) \\cdot VIDYA_{t-1}", "formula_sympy": "alpha * abs(CMO_t) * C_t + (1 - alpha * abs(CMO_t)) * VIDYA_prev", "default_params": {"n": 14}, "behavioral_claim": "Modulating smoothing speed by momentum magnitude (via Chande Momentum Oscillator) captures the relationship between directional conviction and response speed — strong momentum means participants are committed and the average should track closely.", "mathematical_wing": ["functional_analysis"], "tags": ["trend", "moving_average", "adaptive", "momentum_modulated"], "source": "Tushar Chande", "notes": "CMO provides both direction and magnitude; VIDYA uses only magnitude."}

# ═══════════════════════════════════════════════════════════════════════
# OSCILLATORS & MOMENTUM (OSC)
# ═══════════════════════════════════════════════════════════════════════

{"category": "OSC", "name": "Relative Strength Index (RSI)", "formula_latex": "RSI = 100 - \\frac{100}{1 + \\frac{AvgGain_n}{AvgLoss_n}}", "formula_sympy": "100 - 100 / (1 + AvgGain / AvgLoss)", "default_params": {"n": 14}, "behavioral_claim": "The ratio of recent gains to losses measures the exhaustion of buying or selling pressure. Extreme readings indicate that one side has dominated so completely that a mean-reversion of the gain/loss balance is statistically likely.", "mathematical_wing": ["probability_information"], "tags": ["momentum", "oscillator", "mean_reversion", "exhaustion", "overbought_oversold"], "source": "J. Welles Wilder", "notes": "Wilder smoothing (RMA) is used, not SMA. This matters for convergence behavior."}

{"category": "OSC", "name": "Stochastic Oscillator", "formula_latex": "\\%K = 100 \\cdot \\frac{C - L_n}{H_n - L_n}, \\quad \\%D = SMA_3(\\%K)", "formula_sympy": "100 * (C - L_n) / (H_n - L_n)", "default_params": {"K_period": 14, "D_period": 3}, "behavioral_claim": "Normalizing the close within the recent range reveals where participants are willing to transact relative to the range boundaries. Persistent closes near the high indicate accumulation; near the low, distribution.", "mathematical_wing": ["probability_information"], "tags": ["momentum", "oscillator", "range_position", "accumulation_distribution"], "source": "George Lane", "notes": "%K/%D crossovers signal momentum shifts within the range."}

{"category": "OSC", "name": "Stochastic RSI", "formula_latex": "StochRSI = \\frac{RSI - \\min(RSI_n)}{\\max(RSI_n) - \\min(RSI_n)}", "formula_sympy": "(RSI - min_RSI_n) / (max_RSI_n - min_RSI_n)", "default_params": {"rsi_period": 14, "stoch_period": 14, "K": 3, "D": 3}, "behavioral_claim": "Applying the stochastic normalization to RSI itself amplifies sensitivity to momentum regime changes — it detects when RSI is at extreme values relative to its own recent history, revealing second-order exhaustion.", "mathematical_wing": ["probability_information"], "tags": ["momentum", "oscillator", "second_order", "sensitivity_amplification"], "source": "Tushar Chande / Stanley Kroll", "notes": "Faster signals than RSI alone; higher false positive rate."}

{"category": "OSC", "name": "MACD", "formula_latex": "MACD = EMA_{12}(C) - EMA_{26}(C), \\quad Signal = EMA_9(MACD), \\quad Hist = MACD - Signal", "formula_sympy": "EMA(C, 12) - EMA(C, 26)", "default_params": {"fast": 12, "slow": 26, "signal": 9}, "behavioral_claim": "The difference between two EMAs at different timescales captures the divergence between short-term and medium-term participant consensus. Histogram acceleration/deceleration reveals momentum of the momentum — the rate at which trend conviction is changing.", "mathematical_wing": ["functional_analysis"], "tags": ["momentum", "trend", "dual_timescale", "conviction_rate", "histogram"], "source": "Gerald Appel", "notes": "Histogram is the first derivative of the MACD-Signal spread."}

{"category": "OSC", "name": "Commodity Channel Index (CCI)", "formula_latex": "CCI = \\frac{TP - SMA_n(TP)}{0.015 \\cdot MD_n}, \\quad TP = \\frac{H+L+C}{3}", "formula_sympy": "(TP - SMA(TP, n)) / (0.015 * MeanDeviation(TP, n))", "default_params": {"n": 20}, "behavioral_claim": "Normalizing typical price deviation by mean absolute deviation measures how far price has moved relative to its normal statistical variation. The 0.015 constant calibrates so that ~75% of values fall within ±100, making extreme readings statistically meaningful.", "mathematical_wing": ["probability_information"], "tags": ["momentum", "oscillator", "statistical_deviation", "typical_price"], "source": "Donald Lambert", "notes": "Unbounded — can reach ±300+ during strong trends."}

{"category": "OSC", "name": "Williams %R", "formula_latex": "\\%R = -100 \\cdot \\frac{H_n - C}{H_n - L_n}", "formula_sympy": "-100 * (H_n - C) / (H_n - L_n)", "default_params": {"n": 14}, "behavioral_claim": "Inverse stochastic — measures the close relative to the high of the range rather than the low. Persistent readings near 0 (high of range) indicate strong buying conviction; near -100, selling conviction.", "mathematical_wing": ["probability_information"], "tags": ["momentum", "oscillator", "range_position", "conviction"], "source": "Larry Williams", "notes": "Mathematically equivalent to 100 - %K but with inverted scale convention."}

{"category": "OSC", "name": "Momentum (MOM)", "formula_latex": "MOM_n = C_t - C_{t-n}", "formula_sympy": "C_t - C_(t-n)", "default_params": {"n": 10}, "behavioral_claim": "Raw price change over n periods is the purest measure of directional displacement. Zero-crossings mark where current price exceeds (or falls below) the price n bars ago — the simplest possible trend signal.", "mathematical_wing": ["functional_analysis"], "tags": ["momentum", "raw_displacement", "zero_crossing"], "source": "Classical", "notes": "Unbounded. Not normalized — scale depends on instrument price."}

{"category": "OSC", "name": "Rate of Change (ROC)", "formula_latex": "ROC = \\frac{C_t - C_{t-n}}{C_{t-n}} \\times 100", "formula_sympy": "(C_t - C_(t-n)) / C_(t-n) * 100", "default_params": {"n": 9}, "behavioral_claim": "Percentage price change normalizes momentum across instruments and time periods. Measures the return over n periods, making it directly comparable to expected return distributions.", "mathematical_wing": ["probability_information"], "tags": ["momentum", "percentage_change", "return", "normalized"], "source": "Classical", "notes": "Identical to MOM but expressed as percentage."}

{"category": "OSC", "name": "Awesome Oscillator (AO)", "formula_latex": "AO = SMA_5(Median) - SMA_{34}(Median), \\quad Median = \\frac{H+L}{2}", "formula_sympy": "SMA(Median, 5) - SMA(Median, 34)", "default_params": {"fast": 5, "slow": 34}, "behavioral_claim": "Median price (not close) removes the bias of settlement positioning. The 5/34 SMA difference captures the divergence between very short-term and medium-term fair value as perceived by participants.", "mathematical_wing": ["functional_analysis"], "tags": ["momentum", "median_price", "dual_timescale", "bill_williams"], "source": "Bill Williams", "notes": "Part of the Bill Williams system. Uses median price, not close."}

{"category": "OSC", "name": "Chande Momentum Oscillator (CMO)", "formula_latex": "CMO = 100 \\cdot \\frac{S_u - S_d}{S_u + S_d}", "formula_sympy": "100 * (S_up - S_down) / (S_up + S_down)", "default_params": {"n": 9}, "behavioral_claim": "The ratio of net directional movement to total movement measures the purity of the current trend. CMO = +100 means all moves were up (perfect trend); CMO = 0 means equal up and down (pure chop).", "mathematical_wing": ["probability_information"], "tags": ["momentum", "oscillator", "trend_purity", "directional_efficiency"], "source": "Tushar Chande", "notes": "Closely related to RSI: CMO = 2*RSI - 100."}

{"category": "OSC", "name": "True Strength Index (TSI)", "formula_latex": "TSI = 100 \\cdot \\frac{EMA_{13}(EMA_{25}(\\Delta C))}{EMA_{13}(EMA_{25}(|\\Delta C|))}", "formula_sympy": "100 * EMA(EMA(delta_C, 25), 13) / EMA(EMA(abs(delta_C), 25), 13)", "default_params": {"long": 25, "short": 13}, "behavioral_claim": "Double-smoothed momentum relative to double-smoothed absolute momentum measures trend strength with minimal noise. The double EMA removes both high-frequency and medium-frequency noise from the momentum signal.", "mathematical_wing": ["functional_analysis"], "tags": ["momentum", "double_smoothed", "trend_strength", "noise_reduction"], "source": "William Blau", "notes": "Bounded ±100 in theory. Very smooth — good for divergence detection."}

{"category": "OSC", "name": "Fisher Transform", "formula_latex": "Fisher = \\frac{1}{2} \\ln\\left(\\frac{1+X}{1-X}\\right), \\quad X = \\text{normalized price}", "formula_sympy": "Rational(1, 2) * ln((1 + X) / (1 - X))", "default_params": {"n": 9}, "behavioral_claim": "The inverse hyperbolic tangent transforms a bounded normalized price into an unbounded Gaussian-like distribution, amplifying extreme readings. Turning points in the Fisher Transform correspond to high-probability reversal zones because the transform exaggerates departures from the mean.", "mathematical_wing": ["probability_information", "information_geometry"], "tags": ["momentum", "transform", "gaussian", "turning_points", "amplification"], "source": "John Ehlers", "notes": "X must be clipped to (-1, 1) to avoid log singularity."}

{"category": "OSC", "name": "TRIX", "formula_latex": "TRIX = ROC_1(EMA(EMA(EMA(C, n), n), n))", "formula_sympy": "ROC(EMA(EMA(EMA(C, n), n), n), 1)", "default_params": {"n": 15}, "behavioral_claim": "Triple EMA smoothing eliminates cycles shorter than the period, then the 1-bar rate of change captures the pure trend momentum. Extremely clean signal at the cost of significant lag.", "mathematical_wing": ["functional_analysis"], "tags": ["momentum", "triple_smoothed", "cycle_filter", "clean_signal"], "source": "Jack Hutson", "notes": "Very slow — best for confirming major trend changes."}

{"category": "OSC", "name": "Balance of Power", "formula_latex": "BOP = \\frac{C - O}{H - L}", "formula_sympy": "(C - O) / (H - L)", "default_params": {"smoothing": 14}, "behavioral_claim": "The close-open range relative to the high-low range measures who won the bar — buyers (close > open) or sellers. Normalizing by the full range controls for volatility, isolating the directional conviction signal.", "mathematical_wing": ["probability_information"], "tags": ["momentum", "buyer_seller_balance", "conviction", "bar_structure"], "source": "Igor Livshin", "notes": "Bounded [-1, 1]. Often smoothed with SMA."}

{"category": "OSC", "name": "Relative Vigor Index (RVI)", "formula_latex": "RVI = \\frac{SMA_4(C-O)}{SMA_4(H-L)}", "formula_sympy": "SMA(C - O, 4) / SMA(H - L, 4)", "default_params": {"n": 10}, "behavioral_claim": "Smoothed close-open relative to smoothed high-low measures persistent directional vigor. Unlike BOP which is bar-by-bar, RVI smooths over 4 bars to capture sustained conviction rather than single-bar noise.", "mathematical_wing": ["probability_information"], "tags": ["momentum", "vigor", "sustained_conviction", "smoothed"], "source": "John Ehlers", "notes": "Signal line = 4-bar weighted MA of RVI."}

{"category": "OSC", "name": "Ultimate Oscillator", "formula_latex": "UO = 100 \\cdot \\frac{4 \\cdot BP_7/TR_7 + 2 \\cdot BP_{14}/TR_{14} + BP_{28}/TR_{28}}{4+2+1}", "formula_sympy": "100 * (4*BP7_TR7 + 2*BP14_TR14 + BP28_TR28) / 7", "default_params": {"p1": 7, "p2": 14, "p3": 28}, "behavioral_claim": "Weighting three timescales (4:2:1) captures the alignment of short, medium, and long-term buying pressure relative to true range. Divergences between UO and price are more reliable than single-timescale oscillators because they require multi-scale consensus to form.", "mathematical_wing": ["probability_information", "measure_theory"], "tags": ["momentum", "multi_timescale", "buying_pressure", "divergence"], "source": "Larry Williams", "notes": "BP = Close - min(Low, PrevClose). TR = max(High, PrevClose) - min(Low, PrevClose)."}

{"category": "OSC", "name": "Connors RSI", "formula_latex": "CRSI = \\frac{RSI_3 + StreakRSI + PercentRank}{3}", "formula_sympy": "(RSI(C, 3) + RSI(streak, 2) + PercentRank(ROC, 100)) / 3", "default_params": {"rsi_period": 3, "streak_period": 2, "rank_period": 100}, "behavioral_claim": "Averaging three independent mean-reversion signals (momentum, win/loss streak, and magnitude ranking) creates a composite that fires only when multiple behavioral dimensions agree that a reversal is imminent.", "mathematical_wing": ["probability_information"], "tags": ["momentum", "composite", "mean_reversion", "multi_dimensional"], "source": "Larry Connors", "notes": "Designed for mean-reversion strategies on stocks/ETFs."}

{"category": "OSC", "name": "Know Sure Thing (KST)", "formula_latex": "KST = w_1 SMA(ROC_{10}) + w_2 SMA(ROC_{15}) + w_3 SMA(ROC_{20}) + w_4 SMA(ROC_{30})", "formula_sympy": "w1*SMA(ROC(C,10),10) + w2*SMA(ROC(C,15),10) + w3*SMA(ROC(C,20),10) + w4*SMA(ROC(C,30),15)", "default_params": {"roc_periods": [10, 15, 20, 30], "weights": [1, 2, 3, 4]}, "behavioral_claim": "Weighted sum of smoothed rates of change at four timescales captures the momentum consensus across multiple cycle lengths. The increasing weights emphasize longer cycles, which are more significant for trend identification.", "mathematical_wing": ["functional_analysis"], "tags": ["momentum", "multi_cycle", "weighted_sum", "trend_confirmation"], "source": "Martin Pring", "notes": "Signal line = 9-period SMA of KST."}

{"category": "OSC", "name": "Schaff Trend Cycle (STC)", "formula_latex": "STC = Stoch_2(Stoch_1(MACD))", "formula_sympy": "Stochastic(Stochastic(MACD(C, 23, 50), 10), 10)", "default_params": {"macd_period": 23, "fast_cycle": 50, "slow_cycle": 10}, "behavioral_claim": "Double stochastic normalization of MACD compresses the signal into a 0-100 range with sharp transitions at turning points. The nested normalization amplifies cycle boundaries while eliminating the trend component.", "mathematical_wing": ["probability_information"], "tags": ["momentum", "cycle", "double_stochastic", "turning_points"], "source": "Doug Schaff", "notes": "Faster cycle detection than MACD; designed for forex."}

{"category": "OSC", "name": "Ehlers Cyber Cycle", "formula_latex": "Cycle_t = (1-0.5\\alpha)^2(S_t - 2S_{t-1} + S_{t-2}) + 2(1-\\alpha)Cycle_{t-1} - (1-\\alpha)^2 Cycle_{t-2}", "formula_sympy": "(1-alpha/2)**2*(S_t - 2*S_prev + S_prev2) + 2*(1-alpha)*Cycle_prev - (1-alpha)**2*Cycle_prev2", "default_params": {"alpha": 0.07}, "behavioral_claim": "High-pass filtering followed by smoothing isolates the dominant cycle component from price, separating cyclic participant behavior from trend and noise. The extracted cycle represents the oscillating component of aggregate positioning.", "mathematical_wing": ["functional_analysis", "ergodic_theory"], "tags": ["momentum", "cycle", "high_pass_filter", "signal_processing", "ehlers"], "source": "John Ehlers", "notes": "Alpha = 0.07 corresponds to ~28 bar cycle. Requires smooth input."}

{"category": "OSC", "name": "Laguerre RSI", "formula_latex": "LaRSI = \\frac{CU}{CU + CD}, \\quad \\text{where CU, CD from Laguerre filter}", "formula_sympy": "CU / (CU + CD)", "default_params": {"gamma": 0.5}, "behavioral_claim": "Laguerre filter provides superior smoothing to Wilder's method with a single parameter (gamma), producing an RSI variant that responds to trend changes faster with less whipsaw. Gamma controls the trade-off between smoothness and responsiveness.", "mathematical_wing": ["functional_analysis"], "tags": ["momentum", "oscillator", "laguerre", "adaptive_smoothing", "ehlers"], "source": "John Ehlers", "notes": "Gamma 0.5-0.8. Lower gamma = more responsive. 0-1 bounded."}

{"category": "OSC", "name": "Chaikin Oscillator", "formula_latex": "ChO = EMA_3(ADL) - EMA_{10}(ADL)", "formula_sympy": "EMA(ADL, 3) - EMA(ADL, 10)", "default_params": {"fast": 3, "slow": 10}, "behavioral_claim": "The MACD-style treatment of the Accumulation/Distribution Line reveals acceleration and deceleration of volume-weighted accumulation. Rising ChO means accumulation is accelerating; falling means distribution is accelerating.", "mathematical_wing": ["functional_analysis"], "tags": ["momentum", "volume", "accumulation_acceleration", "adl_derivative"], "source": "Marc Chaikin", "notes": "Based on ADL, which uses the money flow multiplier."}

{"category": "OSC", "name": "Detrended Price Oscillator (DPO)", "formula_latex": "DPO = C_t - SMA_{n}(C)_{t - n/2 - 1}", "formula_sympy": "C_t - SMA(C, n)_(t - n/2 - 1)", "default_params": {"n": 20}, "behavioral_claim": "Subtracting a displaced SMA removes the trend component, isolating the cyclic oscillation. The displacement by n/2+1 bars centers the SMA under the cycle peaks and troughs rather than lagging behind them.", "mathematical_wing": ["functional_analysis", "ergodic_theory"], "tags": ["momentum", "cycle", "detrended", "trend_removal"], "source": "Classical", "notes": "Not plotted in real-time — the displacement means the most recent n/2 bars have no DPO value."}

{"category": "OSC", "name": "Percentage Price Oscillator (PPO)", "formula_latex": "PPO = \\frac{EMA_{fast} - EMA_{slow}}{EMA_{slow}} \\times 100", "formula_sympy": "(EMA(C, fast) - EMA(C, slow)) / EMA(C, slow) * 100", "default_params": {"fast": 12, "slow": 26, "signal": 9}, "behavioral_claim": "Percentage-normalized MACD allows comparison across instruments and time periods. The normalization reveals whether the spread between short and long-term consensus is proportionally significant relative to the current price level.", "mathematical_wing": ["functional_analysis"], "tags": ["momentum", "normalized_macd", "cross_instrument", "percentage"], "source": "Classical", "notes": "Identical to MACD in signal but normalized by the slow EMA."}

{"category": "OSC", "name": "Elder Force Index", "formula_latex": "EFI = EMA_n(V_t \\cdot (C_t - C_{t-1}))", "formula_sympy": "EMA(V * (C_t - C_prev), n)", "default_params": {"n": 13}, "behavioral_claim": "Volume times price change measures the force behind each move. High volume on small moves = absorption; low volume on large moves = vacuum. Smoothing isolates the persistent force from bar-to-bar noise.", "mathematical_wing": ["measure_theory"], "tags": ["momentum", "volume_force", "directional_conviction", "elder"], "source": "Alexander Elder", "notes": "2-period EFI for entries, 13-period for trend direction."}

{"category": "OSC", "name": "Elder Ray (Bull/Bear Power)", "formula_latex": "Bull = H_t - EMA_n(C), \\quad Bear = L_t - EMA_n(C)", "formula_sympy": "H - EMA(C, n)", "default_params": {"n": 13}, "behavioral_claim": "High minus EMA measures the maximum buying enthusiasm above consensus; Low minus EMA measures the maximum selling desperation below consensus. Together they reveal the asymmetry of buyer vs seller conviction.", "mathematical_wing": ["probability_information"], "tags": ["momentum", "buyer_seller_asymmetry", "enthusiasm_desperation", "elder"], "source": "Alexander Elder", "notes": "Used with EMA trend filter: only buy when EMA rising and Bear Power negative but rising."}

{"category": "OSC", "name": "Coppock Curve", "formula_latex": "Coppock = WMA_{10}(ROC_{14} + ROC_{11})", "formula_sympy": "WMA(ROC(C, 14) + ROC(C, 11), 10)", "default_params": {"wma": 10, "roc_long": 14, "roc_short": 11}, "behavioral_claim": "Originally designed for monthly charts, the sum of two ROCs captures the recovery of long-term momentum from major lows. The WMA smoothing produces buy signals when the curve turns up from below zero — indicating that the worst of selling pressure has been absorbed.", "mathematical_wing": ["functional_analysis"], "tags": ["momentum", "long_term", "recovery", "major_bottoms"], "source": "Edwin Coppock", "notes": "Monthly indicator. Parameters based on bereavement recovery periods (11-14 months)."}

{"category": "OSC", "name": "Mass Index", "formula_latex": "MI = \\sum_{i=1}^{25} \\frac{EMA_9(H-L)}{EMA_9(EMA_9(H-L))}", "formula_sympy": "Sum(EMA(H-L, 9) / EMA(EMA(H-L, 9), 9), (i, 1, 25))", "default_params": {"n": 25, "ema": 9}, "behavioral_claim": "The ratio of single-smoothed to double-smoothed range, summed over 25 bars, detects range expansion patterns that precede reversals. When the ratio persistently exceeds 1.0 (range expanding), the sum bulges above 27 — the 'reversal bulge' signal.", "mathematical_wing": ["probability_information"], "tags": ["volatility", "reversal", "range_expansion", "bulge"], "source": "Donald Dorsey", "notes": "Trigger: MI crosses above 27 then back below 26.5."}

{"category": "OSC", "name": "Ease of Movement (EMV)", "formula_latex": "EMV = \\frac{(H_t + L_t)/2 - (H_{t-1} + L_{t-1})/2}{V_t / (H_t - L_t)}", "formula_sympy": "((H + L)/2 - (H_prev + L_prev)/2) / (V / (H - L))", "default_params": {"n": 14}, "behavioral_claim": "Distance moved (median change) divided by the box ratio (volume per unit range) measures how easily price moves relative to the volume required. High EMV = price moves far on little volume = low resistance. Low EMV = heavy volume for small moves = absorption.", "mathematical_wing": ["measure_theory"], "tags": ["momentum", "volume", "ease_of_movement", "resistance", "absorption"], "source": "Richard Arms", "notes": "Typically smoothed with 14-bar SMA. Volume in millions."}

# ═══════════════════════════════════════════════════════════════════════
# VOLATILITY, BANDS & CHANNELS (VOL)
# ═══════════════════════════════════════════════════════════════════════

{"category": "VOL", "name": "Bollinger Bands", "formula_latex": "Mid = SMA_n, \\quad Upper = Mid + k\\sigma_n, \\quad Lower = Mid - k\\sigma_n", "formula_sympy": "SMA(C, n) + k * StdDev(C, n)", "default_params": {"n": 20, "k": 2}, "behavioral_claim": "The standard deviation envelope captures the statistical range of normal price variation. Price touching the upper band is not 'overbought' — it means price is at the edge of recent statistical normality. Sustained walks along the band indicate strong trend, not reversal.", "mathematical_wing": ["probability_information"], "tags": ["volatility", "bands", "standard_deviation", "statistical_range", "squeeze"], "source": "John Bollinger", "notes": "Bandwidth = (Upper - Lower) / Mid. %B = (Close - Lower) / (Upper - Lower)."}

{"category": "VOL", "name": "Keltner Channels", "formula_latex": "Mid = EMA_n, \\quad Upper = Mid + k \\cdot ATR_m, \\quad Lower = Mid - k \\cdot ATR_m", "formula_sympy": "EMA(C, n) + k * ATR(m)", "default_params": {"n": 20, "m": 10, "k": 2}, "behavioral_claim": "ATR-based channels use true range (accounting for gaps) rather than standard deviation, making them more robust to gap-driven volatility spikes. The channel width represents the expected range of price movement given recent volatility conditions.", "mathematical_wing": ["probability_information"], "tags": ["volatility", "channels", "atr", "expected_range", "squeeze"], "source": "Chester Keltner / Linda Raschke", "notes": "Modern version uses EMA + ATR (Raschke). Original used typical price + range."}

{"category": "VOL", "name": "Donchian Channels", "formula_latex": "Upper = \\max(H_1, \\ldots, H_n), \\quad Lower = \\min(L_1, \\ldots, L_n)", "formula_sympy": "Max(H, n)", "default_params": {"n": 20}, "behavioral_claim": "The highest high and lowest low over n periods define the absolute boundary of recent price acceptance. Breakouts beyond these levels represent rejection of the entire recent price range — a strong directional commitment by participants.", "mathematical_wing": ["probability_information"], "tags": ["volatility", "channels", "breakout", "range_boundary", "turtle"], "source": "Richard Donchian", "notes": "Basis of the Turtle Trading system (20/55 day breakout)."}

{"category": "VOL", "name": "Average True Range (ATR)", "formula_latex": "TR = \\max(H-L, |H-C_{t-1}|, |L-C_{t-1}|), \\quad ATR = RMA_n(TR)", "formula_sympy": "RMA(Max(H-L, Abs(H-C_prev), Abs(L-C_prev)), n)", "default_params": {"n": 14}, "behavioral_claim": "True range accounts for gaps (overnight moves) that the simple H-L range misses. ATR measures the expected magnitude of price movement per bar, reflecting the current activity level and risk tolerance of participants.", "mathematical_wing": ["probability_information", "measure_theory"], "tags": ["volatility", "true_range", "risk", "position_sizing", "expected_movement"], "source": "J. Welles Wilder", "notes": "Critical for position sizing, stop placement, and channel width. Wilder smoothing."}

{"category": "VOL", "name": "SuperTrend", "formula_latex": "Upper = HL2 + m \\cdot ATR_n, \\quad Lower = HL2 - m \\cdot ATR_n", "formula_sympy": "(H + L) / 2 + multiplier * ATR(n)", "default_params": {"n": 10, "multiplier": 3}, "behavioral_claim": "A trailing stop that flips direction based on close relative to the ATR band. In an uptrend, the lower band acts as support; the moment price closes below it, the regime flips to downtrend. This captures the binary nature of trend following — you are either long or flat, no ambiguity.", "mathematical_wing": ["probability_information"], "tags": ["volatility", "trend", "trailing_stop", "regime_flip", "binary"], "source": "Olivier Seban", "notes": "Only one band is active at a time (lower in uptrend, upper in downtrend)."}

{"category": "VOL", "name": "Choppiness Index", "formula_latex": "CHOP = 100 \\cdot \\frac{\\log_{10}(ATR_{14} \\cdot 14 / (HH_{14} - LL_{14}))}{\\log_{10}(14)}", "formula_sympy": "100 * log10(Sum(ATR, 14) / (HH_14 - LL_14)) / log10(14)", "default_params": {"n": 14}, "behavioral_claim": "The ratio of total ATR to net directional displacement, log-scaled, measures how choppy (range-bound) vs trending the market is. A perfectly trending market uses all its ATR in one direction; a choppy market uses ATR going back and forth.", "mathematical_wing": ["probability_information", "ergodic_theory"], "tags": ["volatility", "choppiness", "trend_strength", "regime_detection", "fractal"], "source": "Bill Dreiss", "notes": "High values (60+) = choppy. Low values (<40) = trending. Based on fractal dimension concepts."}

{"category": "VOL", "name": "Bollinger Bandwidth", "formula_latex": "BW = \\frac{Upper - Lower}{Mid} = \\frac{2k\\sigma_n}{SMA_n}", "formula_sympy": "2 * k * StdDev(C, n) / SMA(C, n)", "default_params": {"n": 20, "k": 2}, "behavioral_claim": "Normalized volatility width reveals the expansion/contraction cycle. Bandwidth at 6-month lows (squeeze) precedes explosive moves because compressed volatility represents equilibrium — and equilibria break.", "mathematical_wing": ["probability_information"], "tags": ["volatility", "squeeze", "contraction", "expansion_cycle"], "source": "John Bollinger", "notes": "Squeeze = bandwidth at relative low. Headfake = false breakout from squeeze."}

{"category": "VOL", "name": "Historical Volatility (HV)", "formula_latex": "HV = \\sigma(\\ln(C_t / C_{t-1})) \\cdot \\sqrt{252}", "formula_sympy": "StdDev(ln(C_t / C_prev)) * sqrt(252)", "default_params": {"n": 20}, "behavioral_claim": "Annualized standard deviation of log returns measures the realized dispersion of price changes. Log returns ensure multiplicative symmetry (a 10% gain and 10% loss are equal magnitude). This is the ground truth that options pricing models (Black-Scholes) assume is constant but isn't.", "mathematical_wing": ["probability_information", "measure_theory"], "tags": ["volatility", "realized", "log_returns", "annualized", "options_pricing"], "source": "Classical", "notes": "Compare to implied volatility to find IV premium/discount."}

# ═══════════════════════════════════════════════════════════════════════
# VOLUME INDICATORS (VLUM)
# ═══════════════════════════════════════════════════════════════════════

{"category": "VLUM", "name": "On Balance Volume (OBV)", "formula_latex": "OBV_t = OBV_{t-1} + \\begin{cases} V_t & \\text{if } C_t > C_{t-1} \\\\ -V_t & \\text{if } C_t < C_{t-1} \\end{cases}", "formula_sympy": "OBV_prev + sign(C_t - C_prev) * V_t", "default_params": {}, "behavioral_claim": "Cumulative signed volume measures the running total of buying vs selling pressure. OBV diverging from price (price making new highs but OBV not confirming) reveals that volume conviction is not supporting the move — smart money may be distributing into strength.", "mathematical_wing": ["measure_theory"], "tags": ["volume", "cumulative", "divergence", "smart_money", "conviction"], "source": "Joe Granville", "notes": "Direction of OBV matters more than absolute value."}

{"category": "VLUM", "name": "Accumulation/Distribution Line (ADL)", "formula_latex": "MFM = \\frac{(C-L)-(H-C)}{H-L}, \\quad ADL_t = ADL_{t-1} + MFM \\cdot V_t", "formula_sympy": "ADL_prev + ((C - L) - (H - C)) / (H - L) * V", "default_params": {}, "behavioral_claim": "The money flow multiplier weights volume by where the close falls within the bar's range. Close near the high = buying volume; near the low = selling volume. This is more nuanced than OBV's binary classification because it captures the degree of buying/selling within each bar.", "mathematical_wing": ["measure_theory"], "tags": ["volume", "accumulation", "distribution", "money_flow", "range_weighted"], "source": "Marc Chaikin", "notes": "MFM ranges from -1 (close = low) to +1 (close = high)."}

{"category": "VLUM", "name": "Chaikin Money Flow (CMF)", "formula_latex": "CMF = \\frac{\\sum_{i=1}^{n} MFM_i \\cdot V_i}{\\sum_{i=1}^{n} V_i}", "formula_sympy": "Sum(MFM * V, n) / Sum(V, n)", "default_params": {"n": 21}, "behavioral_claim": "Volume-weighted average of the money flow multiplier over n periods measures persistent accumulation or distribution pressure. Unlike the cumulative ADL, CMF is bounded and mean-reverting, making it suitable for oscillator-style analysis.", "mathematical_wing": ["measure_theory", "probability_information"], "tags": ["volume", "money_flow", "bounded", "accumulation_distribution"], "source": "Marc Chaikin", "notes": "Bounded approximately [-1, 1]. Above 0 = accumulation. Below 0 = distribution."}

{"category": "VLUM", "name": "Money Flow Index (MFI)", "formula_latex": "MFI = 100 - \\frac{100}{1 + \\frac{\\text{Positive MF}_n}{\\text{Negative MF}_n}}, \\quad MF = TP \\cdot V", "formula_sympy": "100 - 100 / (1 + PosMF / NegMF)", "default_params": {"n": 14}, "behavioral_claim": "RSI applied to money flow (typical price × volume) rather than price alone. This captures not just whether price moved up or down, but whether capital was flowing in or out. MFI divergences from price are stronger than RSI divergences because they include volume conviction.", "mathematical_wing": ["probability_information", "measure_theory"], "tags": ["volume", "money_flow", "rsi_variant", "capital_flow", "overbought_oversold"], "source": "Gene Quong / Avrum Soudack", "notes": "Often called 'volume-weighted RSI'. 80/20 overbought/oversold levels."}

{"category": "VLUM", "name": "Volume Weighted Average Price (VWAP)", "formula_latex": "VWAP = \\frac{\\sum TP_i \\cdot V_i}{\\sum V_i}", "formula_sympy": "Sum(TP * V) / Sum(V)", "default_params": {"reset": "session"}, "behavioral_claim": "The volume-weighted average transaction price reveals the true average cost basis of all participants during the session. Institutional traders use VWAP as a benchmark — buying below VWAP and selling above it ensures execution quality. Price persistently below VWAP indicates institutional selling pressure.", "mathematical_wing": ["measure_theory"], "tags": ["volume", "institutional", "benchmark", "cost_basis", "execution_quality"], "source": "Institutional", "notes": "Resets at session start. Standard deviation bands (1σ, 2σ) define expected range around VWAP."}

{"category": "VLUM", "name": "Klinger Oscillator", "formula_latex": "KO = EMA_{34}(VF) - EMA_{55}(VF), \\quad VF = V \\cdot |2 \\cdot MFM - 1| \\cdot sign(trend)", "formula_sympy": "EMA(VF, 34) - EMA(VF, 55)", "default_params": {"fast": 34, "slow": 55}, "behavioral_claim": "Volume force incorporates both volume magnitude and price trend direction, then applies a MACD-style dual EMA to detect acceleration of volume-weighted trend conviction. Divergences between KO and price reveal when volume is no longer supporting the trend.", "mathematical_wing": ["functional_analysis", "measure_theory"], "tags": ["volume", "volume_force", "dual_ema", "trend_conviction", "divergence"], "source": "Stephen Klinger", "notes": "Signal line = 13-period EMA of KO."}

{"category": "VLUM", "name": "Price Volume Trend (PVT)", "formula_latex": "PVT_t = PVT_{t-1} + V_t \\cdot \\frac{C_t - C_{t-1}}{C_{t-1}}", "formula_sympy": "PVT_prev + V * (C_t - C_prev) / C_prev", "default_params": {}, "behavioral_claim": "Unlike OBV which assigns all volume as buying or selling, PVT weights volume by the percentage price change. A 1% up move with 1M volume adds 10,000; a 0.1% up move with 1M volume adds only 1,000. This captures the proportional conviction behind each move.", "mathematical_wing": ["measure_theory"], "tags": ["volume", "cumulative", "proportional_conviction", "percentage_weighted"], "source": "Classical", "notes": "More gradual than OBV. Better for detecting subtle divergences."}

{"category": "VLUM", "name": "Negative Volume Index (NVI)", "formula_latex": "NVI_t = \\begin{cases} NVI_{t-1} + ROC_1 & \\text{if } V_t < V_{t-1} \\\\ NVI_{t-1} & \\text{otherwise} \\end{cases}", "formula_sympy": "NVI_prev + ROC if V < V_prev else NVI_prev", "default_params": {}, "behavioral_claim": "NVI only accumulates returns on down-volume days, under the theory that smart money operates on quiet days while the crowd trades on high-volume days. Rising NVI on quiet volume = informed accumulation.", "mathematical_wing": ["measure_theory", "probability_information"], "tags": ["volume", "smart_money", "quiet_days", "informed_trading"], "source": "Paul Dysart / Norman Fosback", "notes": "Compare with 255-day EMA. NVI > EMA = bullish 96% of the time (Fosback)."}

{"category": "VLUM", "name": "Positive Volume Index (PVI)", "formula_latex": "PVI_t = \\begin{cases} PVI_{t-1} + ROC_1 & \\text{if } V_t > V_{t-1} \\\\ PVI_{t-1} & \\text{otherwise} \\end{cases}", "formula_sympy": "PVI_prev + ROC if V > V_prev else PVI_prev", "default_params": {}, "behavioral_claim": "PVI accumulates returns only on up-volume days, capturing crowd behavior. Divergence between PVI and NVI reveals disagreement between informed and uninformed participants.", "mathematical_wing": ["measure_theory", "probability_information"], "tags": ["volume", "crowd_behavior", "uninformed_trading", "high_volume_days"], "source": "Paul Dysart / Norman Fosback", "notes": "Complement to NVI. Together they separate smart money from crowd flows."}

# ═══════════════════════════════════════════════════════════════════════
# OVERLAYS & SPECIALIZED TREND (OVR)
# ═══════════════════════════════════════════════════════════════════════

{"category": "OVR", "name": "Ichimoku Cloud", "formula_latex": "Tenkan = \\frac{HH_9+LL_9}{2}, \\quad Kijun = \\frac{HH_{26}+LL_{26}}{2}, \\quad Senkou A = \\frac{Tenkan+Kijun}{2}", "formula_sympy": "(Max(H, 9) + Min(L, 9)) / 2", "default_params": {"tenkan": 9, "kijun": 26, "senkou_b": 52}, "behavioral_claim": "Five lines at three timescales create a complete trend-identification framework. The cloud (kumo) represents future support/resistance displaced 26 periods forward. Price above a rising cloud with Tenkan > Kijun represents maximum trend alignment — all timescales agree.", "mathematical_wing": ["functional_analysis"], "tags": ["trend", "multi_timescale", "cloud", "support_resistance", "complete_system"], "source": "Goichi Hosoda", "notes": "Designed for Japanese rice markets. Parameters based on Japanese trading week/month."}

{"category": "OVR", "name": "Parabolic SAR", "formula_latex": "SAR_t = SAR_{t-1} + AF(EP - SAR_{t-1}), \\quad AF: 0.02 \\to 0.20", "formula_sympy": "SAR_prev + AF * (EP - SAR_prev)", "default_params": {"af_start": 0.02, "af_max": 0.20}, "behavioral_claim": "The acceleration factor creates a parabolic curve that tightens toward price over time, modeling the increasing urgency to exit a trend as it matures. New extreme points increase the acceleration, capturing the positive feedback loop of trend-following behavior.", "mathematical_wing": ["functional_analysis"], "tags": ["trend", "trailing_stop", "acceleration", "time_decay", "exit_signal"], "source": "J. Welles Wilder", "notes": "Flips on touch. Not suitable for ranging markets."}

{"category": "OVR", "name": "Average Directional Index (ADX)", "formula_latex": "ADX = SMA_n\\left(\\frac{|+DI - (-DI)|}{+DI + (-DI)}\\right) \\times 100", "formula_sympy": "SMA(abs(pDI - nDI) / (pDI + nDI), n) * 100", "default_params": {"n": 14}, "behavioral_claim": "ADX measures trend strength regardless of direction. Rising ADX means the spread between buying and selling directional movement is increasing — participants are committing to one side. ADX below 20 = no trend conviction. Above 40 = strong commitment.", "mathematical_wing": ["probability_information"], "tags": ["trend", "strength", "directional_movement", "regime_detection", "commitment"], "source": "J. Welles Wilder", "notes": "+DI and -DI provide direction. ADX provides only magnitude."}

{"category": "OVR", "name": "Aroon", "formula_latex": "Aroon Up = 100 \\cdot \\frac{n - \\text{bars since highest high}}{n}", "formula_sympy": "100 * (n - bars_since_HH) / n", "default_params": {"n": 14}, "behavioral_claim": "Recency of highs vs lows measures trend freshness. Aroon Up at 100 means the highest high was today — the uptrend is as fresh as possible. Aroon crossing signals that the character of highs vs lows is changing — a structural trend shift.", "mathematical_wing": ["probability_information"], "tags": ["trend", "recency", "freshness", "structural_shift"], "source": "Tushar Chande", "notes": "Aroon Oscillator = Aroon Up - Aroon Down."}

{"category": "OVR", "name": "Williams Alligator", "formula_latex": "Jaw = SMMA_{13}(HL2, 8), \\quad Teeth = SMMA_8(HL2, 5), \\quad Lips = SMMA_5(HL2, 3)", "formula_sympy": "SMMA(MedianPrice, 13, offset=8)", "default_params": {"jaw": [13, 8], "teeth": [8, 5], "lips": [5, 3]}, "behavioral_claim": "Three displaced smoothed MAs at different speeds model the 'sleeping' (intertwined = no trend) and 'feeding' (spread apart = trending) states of the market. The biological metaphor captures the alternating phases of consolidation and directional movement.", "mathematical_wing": ["functional_analysis"], "tags": ["trend", "displaced_ma", "regime", "sleeping_feeding", "bill_williams"], "source": "Bill Williams", "notes": "Part of the Bill Williams Profitunity system. Uses median price, not close."}

{"category": "OVR", "name": "Pivot Points (Standard)", "formula_latex": "PP = \\frac{H+L+C}{3}, \\quad R1 = 2PP - L, \\quad S1 = 2PP - H", "formula_sympy": "(H + L + C) / 3", "default_params": {"period": "daily"}, "behavioral_claim": "The previous period's HLC midpoint acts as the equilibrium price around which the current period's trading organizes. Support and resistance levels derived from it represent the mathematical boundaries of expected price action given yesterday's range.", "mathematical_wing": ["probability_information"], "tags": ["support_resistance", "equilibrium", "daily_range", "institutional"], "source": "Floor traders", "notes": "4 styles: Standard, Fibonacci, Woodie, Camarilla."}

{"category": "OVR", "name": "Camarilla Pivot Points", "formula_latex": "R4 = C + (H-L) \\cdot 1.1/2, \\quad R3 = C + (H-L) \\cdot 1.1/4", "formula_sympy": "C + (H - L) * 1.1 / 2", "default_params": {"period": "daily"}, "behavioral_claim": "Close-weighted pivots with proprietary multipliers generate tighter support/resistance levels optimized for intraday mean-reversion. R3/S3 are the key levels — price reaching them from inside typically reverts. R4/S4 are breakout levels.", "mathematical_wing": ["probability_information"], "tags": ["support_resistance", "intraday", "mean_reversion", "breakout_levels"], "source": "Nick Scott", "notes": "Close-weighted (not HL2) gives more weight to settlement positioning."}

{"category": "OVR", "name": "Zig Zag", "formula_latex": "\\text{Connect swing highs/lows where reversal} > \\delta\\%", "formula_sympy": null, "default_params": {"deviation": "5%"}, "behavioral_claim": "Connecting only significant swings (above a threshold) reveals the structural skeleton of price action — the sequence of higher highs, higher lows (uptrend) or lower highs, lower lows (downtrend). Filters out noise to expose the trend architecture.", "mathematical_wing": ["topology_geometry"], "tags": ["structure", "swing_points", "trend_skeleton", "noise_filter"], "source": "Classical", "notes": "Repaints — last segment can change. Use for structure analysis, not trading signals."}

# ═══════════════════════════════════════════════════════════════════════
# ORDER FLOW & MICROSTRUCTURE (OF) — NEW CATEGORY
# This is our core competency. These connect directly to MBOEvent data.
# ═══════════════════════════════════════════════════════════════════════

{"category": "OF", "name": "Order Flow Imbalance (OFI)", "formula_latex": "OFI = \\sum_{\\text{window}} V_{buy}^{agg} - \\sum_{\\text{window}} V_{sell}^{agg}", "formula_sympy": "Sum(V_buy_aggressive) - Sum(V_sell_aggressive)", "default_params": {"window_seconds": 30}, "behavioral_claim": "Net aggressive volume captures the instantaneous demand-supply imbalance. Aggressive buyers lift offers (bullish); aggressive sellers hit bids (bearish). The imbalance measures who is more urgently trying to transact — the side with more urgency sets the price direction.", "mathematical_wing": ["measure_theory"], "tags": ["order_flow", "imbalance", "aggressive_volume", "demand_supply", "urgency"], "source": "Market microstructure", "notes": "Core signal in Formula Foundry. Z-scored against rolling baseline for trigger detection."}

{"category": "OF", "name": "Cumulative Volume Delta (CVD)", "formula_latex": "CVD_t = CVD_{t-1} + (V_{buy}^{agg} - V_{sell}^{agg})_t", "formula_sympy": "CVD_prev + V_buy_agg - V_sell_agg", "default_params": {}, "behavioral_claim": "Running total of aggressive buy minus sell volume reveals persistent accumulation or distribution over time. CVD divergence from price (price rising but CVD falling) indicates the move is not supported by aggressive capital — it's being sold into.", "mathematical_wing": ["measure_theory"], "tags": ["order_flow", "cumulative_delta", "divergence", "accumulation_distribution"], "source": "Market microstructure", "notes": "Similar to OBV but uses aggressive-side classification rather than close vs previous close."}

{"category": "OF", "name": "Kyle's Lambda (Price Impact Coefficient)", "formula_latex": "\\Delta p = \\lambda \\cdot OFI + \\epsilon", "formula_sympy": "lambda_coeff * OFI", "default_params": {"estimation_window": "30min bars"}, "behavioral_claim": "Lambda measures how much price moves per unit of order flow imbalance — the market's sensitivity to informed trading. High lambda = illiquid, information-sensitive market. Low lambda = deep, resilient market. Lambda spikes during panic indicate market makers withdrawing.", "mathematical_wing": ["measure_theory", "information_geometry"], "tags": ["order_flow", "price_impact", "liquidity", "informed_trading", "market_maker"], "source": "Albert Kyle (1985)", "notes": "Estimated via OLS regression of price change on signed volume. R² indicates information content."}

{"category": "OF", "name": "Hawkes Intensity (Self-Exciting Process)", "formula_latex": "\\lambda(t) = \\mu + \\sum_{t_i < t} \\alpha \\beta e^{-\\beta(t - t_i)}", "formula_sympy": "mu + alpha * beta * Sum(exp(-beta * (t - t_i)))", "default_params": {"mu": 0.1, "alpha": 0.5, "beta": 1.0}, "behavioral_claim": "Each aggressive trade increases the probability of the next aggressive trade, capturing the self-exciting cascade dynamics of panic. The exponential decay means the excitation effect fades over time — but during a crash, new events arrive faster than the decay, creating a runaway feedback loop.", "mathematical_wing": ["probability_information", "measure_theory"], "tags": ["order_flow", "self_exciting", "cascade", "feedback_loop", "panic", "point_process"], "source": "Alan Hawkes (1971) / Market microstructure application", "notes": "Core to Formula Foundry's panic detection. Alpha/beta ratio controls the branching ratio."}

{"category": "OF", "name": "Trade Arrival Rate", "formula_latex": "\\lambda_T(t) = \\frac{N_{trades}(t, t+\\Delta t)}{\\Delta t}", "formula_sympy": "N_trades / delta_t", "default_params": {"delta_t": "1 second"}, "behavioral_claim": "The rate at which trades arrive measures market activity intensity. Spike in arrival rate without proportional price change indicates absorption (large limit orders absorbing aggression). Spike with large price change indicates vacuum (no resting liquidity).", "mathematical_wing": ["probability_information"], "tags": ["order_flow", "arrival_rate", "activity", "absorption", "vacuum"], "source": "Market microstructure", "notes": "Poisson process assumption is violated during crisis — Hawkes captures this."}

{"category": "OF", "name": "VPIN (Volume-Synchronized Probability of Informed Trading)", "formula_latex": "VPIN = \\frac{\\sum_{\\tau=1}^{n} |V_{buy}^\\tau - V_{sell}^\\tau|}{n \\cdot V_{bar}}", "formula_sympy": "Sum(abs(V_buy - V_sell), n) / (n * V_bar)", "default_params": {"n": 50, "volume_bar_size": "1/50 of daily volume"}, "behavioral_claim": "The average absolute order imbalance over volume bars estimates the probability that a randomly selected trade is informed. High VPIN precedes adverse price moves because it detects the footprint of informed traders who know something the market hasn't priced yet.", "mathematical_wing": ["probability_information", "information_geometry"], "tags": ["order_flow", "informed_trading", "toxicity", "adverse_selection", "flash_crash"], "source": "Easley, Lopez de Prado, O'Hara (2011)", "notes": "Predicted the 2010 Flash Crash 2 hours before. Volume bars, not time bars."}

{"category": "OF", "name": "Order Book Imbalance (Depth Ratio)", "formula_latex": "OBI = \\frac{\\sum_{i=1}^{k} BidSize_i - \\sum_{i=1}^{k} AskSize_i}{\\sum_{i=1}^{k} BidSize_i + \\sum_{i=1}^{k} AskSize_i}", "formula_sympy": "(Sum(BidSize, k) - Sum(AskSize, k)) / (Sum(BidSize, k) + Sum(AskSize, k))", "default_params": {"k": 5}, "behavioral_claim": "The ratio of bid-side to ask-side resting liquidity measures the stated willingness to buy vs sell. Persistent imbalance toward bids suggests support; toward asks suggests resistance. However, large resting orders can be spoofing — the aggressor side (OF-based) is more reliable.", "mathematical_wing": ["measure_theory", "game_theory"], "tags": ["order_flow", "book_imbalance", "depth", "resting_liquidity", "spoofing"], "source": "Market microstructure", "notes": "Requires L2 book data (MBP-10 in our schema). Less reliable than aggressor-based metrics."}

{"category": "OF", "name": "Bid-Ask Spread", "formula_latex": "Spread = Ask_1 - Bid_1, \\quad SpreadBps = \\frac{Spread}{Mid} \\times 10000", "formula_sympy": "(Ask_1 - Bid_1) / ((Ask_1 + Bid_1) / 2) * 10000", "default_params": {}, "behavioral_claim": "The cost of immediacy. Tight spreads indicate competitive market-making and high liquidity. Spread widening signals market maker risk aversion — they are pricing in the probability of adverse selection (trading against informed flow).", "mathematical_wing": ["game_theory", "information_geometry"], "tags": ["order_flow", "spread", "liquidity", "market_maker", "adverse_selection"], "source": "Market microstructure", "notes": "Critical component of the compound panic trigger. Requires L2 data."}

{"category": "OF", "name": "Shannon Entropy (Order Book)", "formula_latex": "H = -\\sum_{i=1}^{n} p_i \\log_2(p_i), \\quad p_i = \\frac{Size_i}{\\sum Size}", "formula_sympy": "-Sum(p_i * log2(p_i))", "default_params": {"levels": 10}, "behavioral_claim": "Entropy of the size distribution across price levels measures how concentrated or dispersed resting liquidity is. Low entropy = liquidity concentrated at one level (fragile — one order cancel can collapse the book). High entropy = evenly distributed (resilient). Entropy collapse precedes price dislocations.", "mathematical_wing": ["information_geometry", "probability_information"], "tags": ["order_flow", "entropy", "fragility", "concentration", "book_structure"], "source": "Information theory / Formula Foundry", "notes": "Core signal in Formula Foundry entropy trigger. Computed over bid-side levels."}

{"category": "OF", "name": "Footprint Imbalance Ratio", "formula_latex": "FIR = \\frac{V_{bid}^{agg}(p)}{V_{ask}^{agg}(p)}", "formula_sympy": "V_bid_agg_at_price / V_ask_agg_at_price", "default_params": {"threshold": 3.0}, "behavioral_claim": "At each price level, the ratio of aggressive buying to selling volume reveals whether that level is being accumulated or distributed. Ratios above 3:1 indicate strong absorption (buyers overwhelming sellers at that price). Stacking of imbalanced levels creates an imbalance tower — a structural directional signal.", "mathematical_wing": ["measure_theory"], "tags": ["order_flow", "footprint", "imbalance", "absorption", "price_level"], "source": "Order flow analysis", "notes": "Requires tick-by-tick data with side classification. Visualized in footprint charts."}

{"category": "OF", "name": "Aggressive Ratio", "formula_latex": "AR = \\frac{V_{aggressive}}{V_{total}}", "formula_sympy": "V_aggressive / V_total", "default_params": {"window": "1 minute"}, "behavioral_claim": "The fraction of total volume that is aggressive (market orders hitting resting limits) measures urgency. High aggressive ratio = participants want to transact NOW regardless of price. Low aggressive ratio = patient limit orders dominating = equilibrium.", "mathematical_wing": ["probability_information"], "tags": ["order_flow", "aggression", "urgency", "patience", "equilibrium"], "source": "Market microstructure", "notes": "Spikes in aggressive ratio precede fast moves."}

{"category": "OF", "name": "Volume Profile (POC/VAH/VAL)", "formula_latex": "POC = \\arg\\max_p V(p), \\quad VAH/VAL = \\text{70\\% of volume range}", "formula_sympy": null, "default_params": {"value_area_pct": 0.70}, "behavioral_claim": "The distribution of volume across price levels reveals where participants have committed the most capital (POC = Point of Control) and the range containing 70% of all volume (Value Area). Price returning to the POC is drawn to the highest-liquidity price — the market's center of gravity.", "mathematical_wing": ["measure_theory", "probability_information"], "tags": ["order_flow", "volume_profile", "value_area", "poc", "center_of_gravity"], "source": "Peter Steidlmayer (Market Profile)", "notes": "Session-based or composite. VAH/VAL act as support/resistance."}

# ═══════════════════════════════════════════════════════════════════════
# MARKET STRUCTURE & PRICE ACTION (MS) — NEW CATEGORY
# ═══════════════════════════════════════════════════════════════════════

{"category": "MS", "name": "Higher Highs / Higher Lows (Trend Structure)", "formula_latex": "\\text{Uptrend: } H_n > H_{n-1} \\wedge L_n > L_{n-1}", "formula_sympy": null, "default_params": {"swing_threshold": "ATR-based"}, "behavioral_claim": "The most fundamental definition of trend. Higher highs indicate buyers are willing to pay more; higher lows indicate sellers cannot push price as low as before. Violation of this structure (lower low in an uptrend) signals structural breakdown of the trend.", "mathematical_wing": ["topology_geometry"], "tags": ["structure", "trend_definition", "swing_points", "structural_breakdown"], "source": "Dow Theory / Charles Dow", "notes": "Requires swing point detection algorithm. ATR-based threshold avoids noise."}

{"category": "MS", "name": "Fibonacci Retracement Levels", "formula_latex": "Level = H - (H - L) \\cdot r, \\quad r \\in \\{0.236, 0.382, 0.500, 0.618, 0.786\\}", "formula_sympy": "H - (H - L) * r", "default_params": {"ratios": [0.236, 0.382, 0.500, 0.618, 0.786]}, "behavioral_claim": "Fibonacci ratios appear as significant retracement levels not because of mystical properties of phi, but because enough participants use them that they become self-fulfilling support/resistance. The 0.618 level is the most widely watched — institutional algorithms place limits there, creating genuine liquidity clusters.", "mathematical_wing": ["algebraic_number_theory"], "tags": ["structure", "retracement", "fibonacci", "self_fulfilling", "liquidity_cluster"], "source": "Classical / Elliott Wave", "notes": "Self-fulfilling prophecy effect makes these empirically significant despite lacking causal mechanism."}

{"category": "MS", "name": "Average Directional Movement Rating (ADXR)", "formula_latex": "ADXR = \\frac{ADX_t + ADX_{t-n}}{2}", "formula_sympy": "(ADX_t + ADX_prev_n) / 2", "default_params": {"n": 14}, "behavioral_claim": "Averaging current and lagged ADX smooths the trend strength signal, providing a more stable measure of whether the market is in a trending or ranging regime. Used as a filter — only take trend-following signals when ADXR is above threshold.", "mathematical_wing": ["probability_information"], "tags": ["trend", "strength", "regime_filter", "smoothed"], "source": "J. Welles Wilder", "notes": "Conservative filter. Rising ADXR confirms regime is trending."}

{"category": "MS", "name": "Heikin-Ashi Candles", "formula_latex": "HA_C = \\frac{O+H+L+C}{4}, \\quad HA_O = \\frac{HA_{O_{prev}} + HA_{C_{prev}}}{2}", "formula_sympy": "(O + H + L + C) / 4", "default_params": {}, "behavioral_claim": "Averaging open/close with previous HA values creates smoother candles that filter bar-to-bar noise. The transformation reveals trend persistence — a series of bodyless HA candles (doji) indicates indecision, while full-bodied candles with no opposite wick indicate strong commitment.", "mathematical_wing": ["functional_analysis"], "tags": ["structure", "candle_transform", "noise_filter", "trend_persistence"], "source": "Munehisa Homma (attributed)", "notes": "Do NOT use HA values for backtesting entry/exit prices — they are transformed, not real prices."}

{"category": "MS", "name": "Tom DeMark TD Sequential", "formula_latex": "\\text{Setup: 9 consecutive closes} < C_{i-4}; \\quad \\text{Countdown: 13 closes} \\leq L_{i-2}", "formula_sympy": null, "default_params": {"setup": 9, "countdown": 13, "lookback": 4}, "behavioral_claim": "The 9-count setup identifies trend exhaustion by counting consecutive closes beyond a lookback reference. The 13-count countdown then measures the deceleration of the trend. Completion of both counts indicates that the behavioral pattern of trend-following has reached its statistical limit.", "mathematical_wing": ["probability_information"], "tags": ["structure", "exhaustion", "sequential", "count_pattern", "reversal"], "source": "Tom DeMark", "notes": "Proprietary system with many nuances. Setup flip resets the count."}

{"category": "MS", "name": "DeMark Range Expansion Index (REI)", "formula_latex": "REI = 100 \\cdot \\frac{\\sum \\text{filtered range diffs}}{\\sum |\\text{range diffs}|}", "formula_sympy": "100 * Sum(filtered_diff) / Sum(abs(diff))", "default_params": {"n": 8}, "behavioral_claim": "Filtered range differences (only counting when specific conditions are met) isolate genuine range expansion from noise. REI near ±100 indicates strong directional range expansion; near 0 indicates choppy, directionless range.", "mathematical_wing": ["probability_information"], "tags": ["structure", "range_expansion", "filtered", "directional"], "source": "Tom DeMark", "notes": "Bounded ±100. Filters require consecutive conditions to be met."}

{"category": "MS", "name": "TTM Squeeze", "formula_latex": "\\text{Squeeze ON: } BB_{upper} < KC_{upper} \\wedge BB_{lower} > KC_{lower}", "formula_sympy": null, "default_params": {"bb": [20, 2], "kc": [20, 1.5]}, "behavioral_claim": "When Bollinger Bands fit inside Keltner Channels, volatility has compressed below normal ATR-based expectations. This represents a coiled spring — participants are in equilibrium and the next directional move will be explosive. The momentum histogram (linear regression slope) indicates the likely direction.", "mathematical_wing": ["probability_information"], "tags": ["volatility", "squeeze", "bollinger_keltner", "coiled_spring", "breakout"], "source": "John Carter", "notes": "Momentum = linear regression slope of close over 20 bars. Direction of first bar after squeeze release is key."}

# ═══════════════════════════════════════════════════════════════════════
# STATISTICAL & REGRESSION-BASED (STAT) — NEW CATEGORY
# ═══════════════════════════════════════════════════════════════════════

{"category": "STAT", "name": "Linear Regression Channel", "formula_latex": "y = a + bt, \\quad \\text{Channel} = y \\pm k\\sigma_{residuals}", "formula_sympy": "a + b * t", "default_params": {"n": 100, "k": 2}, "behavioral_claim": "OLS regression of price on time extracts the systematic trend component. Residuals measure deviation from trend. Price at the channel boundary means the current deviation from trend is statistically extreme — regression toward the channel center is the base expectation.", "mathematical_wing": ["functional_analysis"], "tags": ["regression", "trend", "channel", "mean_reversion", "statistical_extreme"], "source": "Classical statistics", "notes": "Slope = trend rate. R² = trend strength. Channel width = residual volatility."}

{"category": "STAT", "name": "Correlation Coefficient", "formula_latex": "r = \\frac{\\sum (x_i - \\bar{x})(y_i - \\bar{y})}{\\sqrt{\\sum(x_i-\\bar{x})^2 \\sum(y_i-\\bar{y})^2}}", "formula_sympy": "Sum((x - x_mean)*(y - y_mean)) / sqrt(Sum((x - x_mean)**2) * Sum((y - y_mean)**2))", "default_params": {"n": 14}, "behavioral_claim": "Pearson correlation between two series measures the strength of linear co-movement. Applied to price vs time, it measures trend linearity. Applied to two instruments, it measures their behavioral coupling — critical for pairs trading and cross-asset analysis.", "mathematical_wing": ["probability_information"], "tags": ["correlation", "linear_relationship", "pairs", "cross_asset", "coupling"], "source": "Karl Pearson", "notes": "Range [-1, 1]. Used in cross-asset trigger in Formula Foundry."}

{"category": "STAT", "name": "R-Squared (Coefficient of Determination)", "formula_latex": "R^2 = 1 - \\frac{SS_{res}}{SS_{tot}} = 1 - \\frac{\\sum(y_i - \\hat{y}_i)^2}{\\sum(y_i - \\bar{y})^2}", "formula_sympy": "1 - Sum((y - y_hat)**2) / Sum((y - y_mean)**2)", "default_params": {"n": 14}, "behavioral_claim": "The fraction of price variance explained by the linear trend. High R² means price is moving in a straight line (strong trend, low noise). Low R² means noise dominates (ranging, choppy). This is a purer measure of trendiness than ADX because it's based on variance decomposition, not directional movement.", "mathematical_wing": ["probability_information"], "tags": ["regression", "trend_quality", "variance_explained", "noise_ratio"], "source": "Classical statistics", "notes": "R² > 0.8 = very strong linear trend. R² < 0.2 = no trend."}

{"category": "STAT", "name": "Z-Score", "formula_latex": "Z = \\frac{X - \\mu}{\\sigma}", "formula_sympy": "(X - mu) / sigma", "default_params": {"n": 20}, "behavioral_claim": "Normalizing any value by its rolling mean and standard deviation creates a universal scale for comparing deviations across instruments and time periods. Z > 2 means the value is at the 97.5th percentile of its recent distribution — statistically extreme by any measure.", "mathematical_wing": ["probability_information"], "tags": ["normalization", "standard_score", "universal_scale", "extreme_detection"], "source": "Classical statistics", "notes": "Applied to OFI in Formula Foundry trigger system. Foundation of all anomaly detection."}

{"category": "STAT", "name": "Hurst Exponent", "formula_latex": "E[R(n)/S(n)] = C \\cdot n^H", "formula_sympy": "C * n**H", "default_params": {"n_range": [10, 200]}, "behavioral_claim": "H measures the long-range dependence structure of the price series. H = 0.5 = random walk (efficient market). H > 0.5 = persistent (trending, momentum works). H < 0.5 = anti-persistent (mean-reverting). This is the most fundamental measure of which strategy class will work on a given instrument.", "mathematical_wing": ["probability_information", "ergodic_theory"], "tags": ["persistence", "mean_reversion", "random_walk", "long_range_dependence", "regime"], "source": "Harold Edwin Hurst / Benoit Mandelbrot", "notes": "Estimated via R/S analysis or DFA. Regime-dependent — should be computed on rolling windows."}

{"category": "STAT", "name": "Autocorrelation", "formula_latex": "\\rho_k = \\frac{\\sum_{t=1}^{n-k}(r_t - \\bar{r})(r_{t+k} - \\bar{r})}{\\sum_{t=1}^{n}(r_t - \\bar{r})^2}", "formula_sympy": "Sum((r_t - r_mean)*(r_(t+k) - r_mean)) / Sum((r_t - r_mean)**2)", "default_params": {"lag": 1}, "behavioral_claim": "Serial correlation of returns at lag k measures whether past returns predict future returns. Positive autocorrelation = momentum (trends continue). Negative autocorrelation = mean reversion. The sign and magnitude at each lag reveal the memory structure of the market.", "mathematical_wing": ["probability_information", "ergodic_theory"], "tags": ["serial_correlation", "momentum", "mean_reversion", "memory_structure", "predictability"], "source": "Classical statistics", "notes": "Lag-1 autocorrelation for HFT. Longer lags for swing trading."}

# ═══════════════════════════════════════════════════════════════════════
# SENTIMENT & POSITIONING PROXIES (SENT) — NEW CATEGORY
# These capture crowd psychology through observable market data.
# ═══════════════════════════════════════════════════════════════════════

{"category": "SENT", "name": "Put/Call Ratio", "formula_latex": "PCR = \\frac{V_{puts}}{V_{calls}}", "formula_sympy": "V_puts / V_calls", "default_params": {}, "behavioral_claim": "The ratio of put to call volume measures the market's demand for downside protection relative to upside speculation. Extreme PCR readings indicate crowded positioning — when everyone is already hedged (high PCR), the marginal seller is exhausted and reversals become likely.", "mathematical_wing": ["probability_information", "game_theory"], "tags": ["sentiment", "options", "crowding", "exhaustion", "contrarian"], "source": "Options market", "notes": "Equity PCR vs total PCR differ. Smoothed with 5-10 day MA."}

{"category": "SENT", "name": "VIX (Implied Volatility Index)", "formula_latex": "VIX = 100 \\cdot \\sqrt{\\frac{2}{T} \\sum \\frac{\\Delta K_i}{K_i^2} e^{rT} Q(K_i) - \\frac{1}{T}\\left(\\frac{F}{K_0} - 1\\right)^2}", "formula_sympy": null, "default_params": {"T": "30 days"}, "behavioral_claim": "Implied volatility is the market's consensus forecast of future realized volatility, extracted from option prices. VIX spikes represent fear — participants are willing to pay a premium for protection. The gap between implied and realized volatility (variance risk premium) measures the market's risk aversion.", "mathematical_wing": ["probability_information", "measure_theory"], "tags": ["sentiment", "fear", "implied_volatility", "risk_premium", "options_pricing"], "source": "CBOE", "notes": "VIX > 30 = high fear. VIX < 15 = complacency. Mean-reverting."}

{"category": "SENT", "name": "Funding Rate (Crypto Perpetuals)", "formula_latex": "FR = \\text{Premium Rate} + \\text{clamp}(\\text{Interest Rate} - \\text{Premium Rate})", "formula_sympy": "premium_rate + clamp(interest_rate - premium_rate)", "default_params": {"interval": "8 hours"}, "behavioral_claim": "The periodic payment between long and short perpetual futures holders measures the supply/demand imbalance for leverage. Positive funding = longs pay shorts = crowded long. Negative funding = shorts pay longs = crowded short. Extreme funding rates predict forced liquidations.", "mathematical_wing": ["game_theory"], "tags": ["sentiment", "leverage", "crowding", "funding", "liquidation", "crypto"], "source": "BitMEX / Crypto derivatives", "notes": "Crypto-specific. 8-hour intervals on most exchanges. Directly observable."}

{"category": "SENT", "name": "Open Interest Change", "formula_latex": "\\Delta OI = OI_t - OI_{t-1}", "formula_sympy": "OI_t - OI_prev", "default_params": {}, "behavioral_claim": "Rising open interest with rising price = new longs entering (bullish conviction). Rising OI with falling price = new shorts entering (bearish conviction). Falling OI = positions closing (weakening conviction). The combination of price direction and OI change reveals whether moves are driven by new commitment or position unwinding.", "mathematical_wing": ["measure_theory"], "tags": ["sentiment", "positioning", "commitment", "conviction", "unwinding"], "source": "Futures/options markets", "notes": "Available for futures and options. Not available for spot markets."}

{"category": "SENT", "name": "Long/Short Ratio", "formula_latex": "LSR = \\frac{N_{long\\_accounts}}{N_{short\\_accounts}}", "formula_sympy": "N_long / N_short", "default_params": {}, "behavioral_claim": "The ratio of accounts holding long vs short positions measures retail sentiment. Extreme readings are contrarian indicators — when 80%+ of accounts are long, the market is crowded and vulnerable to a long squeeze. The crowd is a reliable counter-indicator at extremes.", "mathematical_wing": ["game_theory", "probability_information"], "tags": ["sentiment", "retail", "crowding", "contrarian", "squeeze_risk"], "source": "Exchange-reported data", "notes": "Available from Binance, Bitfinex, IG, etc. Account-based, not volume-weighted."}

{"category": "SENT", "name": "Liquidation Volume", "formula_latex": "LiqVol = \\sum V_{forced\\_close}", "formula_sympy": "Sum(V_forced_close)", "default_params": {"window": "1 hour"}, "behavioral_claim": "Forced liquidations represent participants whose positions exceeded their risk tolerance. Liquidation cascades create positive feedback loops — each liquidation pushes price further, triggering more liquidations. The rate and magnitude of liquidations directly measures the intensity of forced selling/buying pressure.", "mathematical_wing": ["measure_theory", "game_theory"], "tags": ["sentiment", "liquidation", "forced_selling", "cascade", "feedback_loop", "leverage"], "source": "Crypto exchanges", "notes": "Crypto-specific. Available from exchange APIs. Directly feeds Hawkes intensity."}
